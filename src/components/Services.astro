---
export interface Props {
  lang?: "en" | "es";
}

const { lang = "en" } = Astro.props;

const copy =
  lang === "es"
    ? {
        sectionLabel: "Servicios",
        sectionTitle: "QUÉ",
        sectionTitleOutline: "PRODUCIMOS",
        intro: "Trabajamos en la intersección entre lenguaje audiovisual, dirección visual, postproducción y herramientas generativas.",
        items: [
          {
            num: "01",
            label: "Comerciales",
            title: "AI COMMERCIAL\nPRODUCTION",
            body: "Comerciales de 15 a 60 segundos para marcas y agencias. De brief a entrega en días, no semanas. Calidad premium con dirección creativa humana en cada etapa.",
          },
          {
            num: "02",
            label: "Contenido Continuo",
            title: "AI CONTENT\nENGINE",
            body: "Paquete mensual de piezas para redes sociales con identidad visual consistente generada con IA. Presencia constante sin agotar el presupuesto.",
          },
          {
            num: "03",
            label: "Post-Producción",
            title: "AI POST\nENHANCEMENT",
            body: "Tomamos material existente y lo elevamos: colorización, relighting, efectos y continuidad usando los modelos de IA más avanzados del mercado.",
          },
          {
            num: "04",
            label: "Workflows y Sistemas",
            title: "CREATIVE\nWORKFLOWS",
            body: "Pensamos procesos, conectamos herramientas y organizamos flujos para que la creación con IA no dependa del azar, sino de una lógica que permita iterar, corregir y terminar mejor.",
          },
        ],
      }
    : {
        sectionLabel: "Services",
        sectionTitle: "WHAT",
        sectionTitleOutline: "WE PRODUCE",
        intro: "We work at the intersection of audiovisual language, visual direction, post-production and generative tools.",
        items: [
          {
            num: "01",
            label: "Commercials",
            title: "AI COMMERCIAL\nPRODUCTION",
            body: "15 to 60-second commercials for brands and agencies. From brief to delivery in days, not weeks. Premium quality with human creative direction at every stage.",
          },
          {
            num: "02",
            label: "Ongoing Content",
            title: "AI CONTENT\nENGINE",
            body: "Monthly package of social media pieces with consistent AI-generated visual identity. Constant presence without draining the budget.",
          },
          {
            num: "03",
            label: "Post-Production",
            title: "AI POST\nENHANCEMENT",
            body: "We take existing material and elevate it: colorization, relighting, effects and continuity using the most advanced AI models on the market.",
          },
          {
            num: "04",
            label: "Workflows & Systems",
            title: "CREATIVE\nWORKFLOWS",
            body: "We design processes, connect tools and organize flows so AI creation does not depend on chance, but on a working logic that makes it possible to iterate, correct and finish better.",
          },
        ],
      };
---

<section id="servicios" class="bg-black text-white py-24">
  <div class="container mx-auto px-6">

    <!-- Header -->
    <div class="mb-16">
      <p class="sec-label">{copy.sectionLabel}</p>
      <h2 class="sec-title">
        {copy.sectionTitle}<br/>
        <span class="sec-title-outline">{copy.sectionTitleOutline}</span>
      </h2>
      <p class="sec-intro">{copy.intro}</p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-white/[0.06] max-w-7xl mx-auto">
      {copy.items.map((item) => (
        <article class="svc-card">
          <div class="card-top-line"></div>
          <div class="p-8 md:p-10 flex flex-col gap-5 h-full">

            <div class="flex items-start justify-between gap-4">
              <span class="svc-num">{item.num}</span>
              <span class="svc-label-tag">{item.label}</span>
            </div>

            <h3 class="svc-title">
              {item.title.split('\n').map(line => <span>{line}<br/></span>)}
            </h3>

            <p class="svc-body">{item.body}</p>

            <div class="svc-arrow mt-auto">→</div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Section label ── */
  .sec-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #f6ad1e;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .sec-label::before {
    content: '';
    width: 24px;
    height: 1px;
    background: #f6ad1e;
    display: block;
  }

  /* ── Section title ── */
  .sec-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 7vw, 88px);
    line-height: 0.92;
    letter-spacing: 0.02em;
    color: #ffffff;
    margin-bottom: 24px;
  }
  .sec-title-outline {
    font-family: 'Bebas Neue', sans-serif;
    -webkit-text-stroke: 1px rgba(255,255,255,0.799);
    color: transparent;
  }

  /* ── Intro ── */
  .sec-intro {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    line-height: 1.85;
    max-width: 520px;
  }

  /* ── Card ── */
  .svc-card {
    background: #000000;
    position: relative;
    overflow: hidden;
    transition: background 0.3s ease;
  }
  .svc-card:hover { background: #0a0a0a; }

  .card-top-line {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(to right, #f6ad1e, transparent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }
  .svc-card:hover .card-top-line { transform: scaleX(1); }

  /* ── Number ── */
  .svc-num {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    color: #f6ad1e;
  }

  /* ── Label tag ── */
  .svc-label-tag {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 4px 12px;
    transition: all 0.3s;
  }
  .svc-card:hover .svc-label-tag {
    border-color: rgba(246,173,30,0.25);
    color: rgba(255,255,255,0.7);
  }

  /* ── Service title ── */
  .svc-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(32px, 3.5vw, 48px);
    line-height: 0.92;
    color: #ffffff;
    letter-spacing: 0.02em;
    transition: color 0.3s;
  }
  .svc-card:hover .svc-title { color: #f6ad1e; }

  /* ── Body ── */
  .svc-body {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    line-height: 1.85;
  }

  /* ── Arrow ── */
  .svc-arrow {
    font-family: 'DM Mono', monospace;
    font-size: 18px;
    color: rgba(255,255,255,0.15);
    transition: all 0.3s ease;
  }
  .svc-card:hover .svc-arrow {
    color: #f6ad1e;
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .svc-card > div { padding: 32px 20px; }
  }
</style>