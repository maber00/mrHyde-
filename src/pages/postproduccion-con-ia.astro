---
import ServicePage from "../layouts/ServicePage.astro";

const features = [
  {
    num: "01",
    title: "COLOR Y RELIGHTING",
    body: "Corrección y gradación de color con criterio cinematográfico, y relighting con IA para corregir o reinventar la iluminación de material ya grabado.",
  },
  {
    num: "02",
    title: "EFECTOS Y LIMPIEZA",
    body: "Eliminación de objetos, extensión de set, rotoscopia y efectos visuales con los modelos de IA más avanzados — sin los tiempos de un pipeline VFX tradicional.",
  },
  {
    num: "03",
    title: "CONTINUIDAD Y UPSCALE",
    body: "Reparamos continuidad, estabilizamos, mejoramos resolución y damos acabado a material de archivo o grabado en condiciones difíciles.",
  },
  {
    num: "04",
    title: "ZERO DATA RETENTION",
    body: "Tu material en bruto se procesa bajo Zero Data Retention sobre Google Vertex AI: no se almacena ni entrena modelos externos. Confidencialidad total.",
  },
];

const faqs = [
  {
    q: "¿Qué es la postproducción con IA?",
    a: "Es el uso de modelos generativos y de visión por computadora para elevar material audiovisual ya existente: color, relighting, efectos, limpieza de planos, upscaling y continuidad. Mantiene el criterio de un postproductor humano, pero acelera procesos que antes tomaban días.",
  },
  {
    q: "¿Pueden mejorar un video que ya grabé?",
    a: "Sí. Ese es el corazón del servicio: tomamos tu material existente y lo elevamos — corrección de color, relighting, remoción de objetos, estabilización, upscaling y efectos. No necesitas volver a grabar.",
  },
  {
    q: "¿Cuánto cuesta la postproducción con IA en Colombia?",
    a: "Depende del metraje, la complejidad y el tipo de intervención. En general resulta significativamente más económica y rápida que un pipeline de postproducción tradicional. Contáctanos con una muestra del material para una propuesta concreta.",
  },
  {
    q: "¿Mi material queda protegido durante el proceso?",
    a: "Sí. Procesamos sobre Google Vertex AI con Zero Data Retention activado: tu material no se almacena, no lo revisan humanos de Google y no entrena ningún modelo externo.",
  },
];
---

<ServicePage
  lang="es"
  title="Postproducción con IA en Colombia | Sr. Hide — Color, VFX y Relighting"
  description="Postproducción con inteligencia artificial en Colombia: color, relighting, efectos, limpieza y upscaling de tu material existente. Más rápido y económico que un pipeline tradicional. Con Zero Data Retention."
  label="Servicios"
  h1="POSTPRODUCCIÓN CON IA"
  h1Outline="COLOMBIA Y LATAM"
  breadcrumbName="Postproducción con IA"
  lead="Sr. Hide hace postproducción con inteligencia artificial en Colombia: tomamos material ya grabado y lo elevamos con corrección de color, relighting, efectos visuales, limpieza de planos, estabilización y upscaling. Mantenemos el criterio de un postproductor humano, pero con tiempos y costos muy por debajo de un pipeline tradicional — y todo bajo Zero Data Retention sobre Google Vertex AI."
  features={features}
  faqs={faqs}
  ctaText="¿Tienes material que quieres llevar a otro nivel? Envíanos una muestra y te decimos qué podemos hacer."
  ctaLabel="Hablar con el equipo →"
/>
