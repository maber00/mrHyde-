---
import ServicePage from "../layouts/ServicePage.astro";

const features = [
  {
    num: "01",
    title: "TU CONTENIDO NO SE ALMACENA",
    body: "El material que entra al pipeline de producción no queda guardado en servidores de terceros. No hay copia. No se indexa. No se reutiliza.",
  },
  {
    num: "02",
    title: "NINGÚN HUMANO LO REVISA",
    body: "Con ZDR activado, ningún operador externo ve el contenido generado. Tu material confidencial permanece confidencial.",
  },
  {
    num: "03",
    title: "NO ALIMENTA MODELOS EXTERNOS",
    body: "Tu brief, tu campaña no anunciada y tu identidad visual no se usan para entrenar nada que no sea tuyo. Lo tuyo sigue siendo tuyo.",
  },
  {
    num: "04",
    title: "GARANTÍA CONTRACTUAL DE GOOGLE",
    body: "No es una promesa nuestra: es una condición del contrato con Google Vertex AI. Sr. Hide es el único estudio audiovisual en LATAM que opera bajo este marco.",
  },
];

const faqs = [
  {
    q: "¿Qué es Zero Data Retention?",
    a: "Es una condición de Google Vertex AI que garantiza que el contenido procesado no se almacena, no es revisado por humanos y no entrena ningún modelo externo. No es una promesa de marketing — está en el contrato.",
  },
  {
    q: "¿Por qué importa para mi marca?",
    a: "Si manejas campañas no anunciadas, contenido sensible o trabajas en un sector regulado — farmacéutico, financiero, legal, gobierno — ZDR es la diferencia entre producir con seguridad y asumir un riesgo innecesario.",
  },
  {
    q: "¿Otras productoras ofrecen esto?",
    a: "No en LATAM. La mayoría usa herramientas de consumo cuyos términos permiten almacenar y reutilizar el contenido. Sr. Hide es el único estudio audiovisual en la región que opera sobre Google Vertex AI con ZDR activado.",
  },
  {
    q: "¿Cómo sé que es real?",
    a: "Es una condición documentada de Google Cloud. Podemos explicarte exactamente sobre qué infraestructura operamos y por qué tu contenido queda protegido bajo ese acuerdo.",
  },
];
---

<ServicePage
  lang="es"
  title="Zero Data Retention en Producción Audiovisual | Sr. Hide Colombia"
  description="El único estudio en LATAM con Zero Data Retention sobre Google Vertex AI. Tu contenido no se almacena, no lo revisa nadie y no alimenta ningún modelo externo. Garantía contractual de Google."
  label="Diferenciador"
  h1="ZERO DATA RETENTION"
  h1Outline="PRODUCCIÓN AUDIOVISUAL"
  breadcrumbName="Zero Data Retention"
  lead="Sr. Hide es el único estudio de producción audiovisual en América Latina que opera con Zero Data Retention sobre Google Vertex AI. Tu contenido no se almacena, nadie externo lo revisa y no se usa para entrenar nada. No es una promesa — es una condición del contrato con Google."
  features={features}
  faqs={faqs}
  ctaText="¿Tu contenido es confidencial o tu sector está regulado? Hablemos."
  ctaLabel="Hablar con el equipo →"
  altEsPath="/zero-data-retention-produccion-audiovisual/"
  altEnPath="/en/zero-data-retention-video-production/"
/>