---
import { Image } from 'astro:assets';

interface Props {
  lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props;

const logoAlt = lang === 'es' ? 'Logo de marca' : 'Brand Logo';

// Importar los 24 logos automáticamente
const logos = Array.from({ length: 24 }, (_, i) => {
  const number = i + 1;
  return import(`../assets/icon/${number}.png`);
});
---

<div class="carousel">
  <div class="carousel-inner">
    {logos.map((logo, index) => (
      <div class="carousel-item">
        <Image src={logo} alt={`${logoAlt} ${index + 1}`} class="carousel-logo" />
      </div>
    ))}

    {logos.map((logo, index) => (
      <div class="carousel-item">
        <Image src={logo} alt={`${logoAlt} ${index + 1}`} class="carousel-logo" />
      </div>
    ))}
  </div>
</div>

<style>
  .carousel {
    @apply w-full overflow-hidden relative;
  }

  .carousel-inner {
    @apply flex;
    animation: marquee 40s linear infinite;
    width: calc((100px + 32px) * 48);
  }

  .carousel-item {
    @apply flex-shrink-0 mx-4;
    width: 100px;
    height: 100px;
  }

  .carousel-logo {
    @apply w-full h-full object-contain;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .carousel:hover .carousel-inner {
    animation-play-state: paused;
  }
</style>