---
export interface Props {
  lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props;

const copy = lang === 'es'
  ? {
      eyebrow: 'Producción Audiovisual · Inteligencia Artificial · Bogotá — LATAM',
      titleLine1: 'MENOS',
      titleLine2: 'FRICCIÓN',
      titleLine3: 'MÁS',
      titleLine4: 'OBRA',
      titleLine5: 'TERMINADA',
      ctaPrimary: 'Ver portafolio',
      ctaSecondary: 'Cómo trabajamos',
      ctaContact: 'Hablemos',
    }
  : {
      eyebrow: 'Audiovisual Production · Artificial Intelligence · Bogotá — LATAM',
      titleLine1: 'LESS',
      titleLine2: 'FRICTION',
      titleLine3: 'MORE',
      titleLine4: 'FINISHED',
      titleLine5: 'WORK',
      ctaPrimary: 'View Portfolio',
      ctaSecondary: 'How we work',
      ctaContact: "Let's talk",
    };
---

<section id="inicio" class="hero-container relative w-full h-screen overflow-hidden bg-black flex items-end">

  <!-- Video background — lazy loaded para no bloquear LCP -->
  <div class="absolute inset-0 w-full h-full z-0" id="heroVideoWrapper">
    <div class="absolute inset-0 w-full h-full video-container overflow-hidden">
      <iframe
        id="backgroundVideo"
        title={lang === 'es' ? 'Video de fondo' : 'Background video'}
        data-src="https://player.vimeo.com/video/1163773815?background=1&autoplay=1&loop=1&muted=1&controls=0&title=0&byline=0&portrait=0&dnt=1"
        src="about:blank"
        class="absolute top-1/2 left-1/2 w-[200vw] h-[200vh] -translate-x-1/2 -translate-y-1/2"
        frameborder="0"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        aria-hidden="true"
        tabindex="-1"
      ></iframe>
    </div>
  </div>

  <!-- Overlays -->
  <div class="absolute inset-0 bg-black/60 z-10"></div>
  <div class="hero-grid absolute inset-0 z-10 pointer-events-none"></div>
  <div class="hero-glow absolute z-10 pointer-events-none"></div>

  <!-- Content -->
  <div class="relative z-20 w-full">
    <div class="px-6 sm:px-12 md:px-16 lg:px-24 pb-14 md:pb-30">
 <!-- Eyebrow -->
      

      <!-- Big title -->
      <h1 class="hero-title leading-[0.88]">
        <span class="title-solid">{copy.titleLine1}</span><br/>
        <span class="title-outline">{copy.titleLine2}</span><br/>
        <span class="title-solid">{copy.titleLine3} </span><span class="title-accent">{copy.titleLine4}</span><br/>
        <span class="title-outline">{copy.titleLine5}</span>
      </h1>

      <!-- Bottom row -->
      <div class="mt-10 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6">
        {lang === 'es' ? (
          <p class="hero-lead text-sm sm:text-base md:text-lg text-white/75 max-w-lg leading-relaxed font-light">
            Estudio de producción audiovisual que integra <strong class="text-white/90 font-medium">inteligencia artificial</strong> como método de trabajo. Mismo estándar creativo. Menos tiempo. Menos costos. Y el único en LATAM con <strong class="text-[#f6ad1e] font-medium">Zero Data Retention</strong> — tu contenido no alimenta ningún modelo externo.
          </p>
        ) : (
          <p class="hero-lead text-sm sm:text-base md:text-lg text-white/75 max-w-lg leading-relaxed font-light">
            Audiovisual production studio that integrates <strong class="text-white/90 font-medium">artificial intelligence</strong> as a working method. Same creative standard. Less time. Lower costs. The only studio in LATAM with <strong class="text-[#f6ad1e] font-medium">Zero Data Retention</strong> — your content never feeds any external model.
          </p>
        )}

        <div class="flex flex-wrap gap-3">
          <a
            href="#portafolio"
            class="btn-primary inline-flex items-center px-6 py-3 text-xs sm:text-sm uppercase tracking-[0.12em] text-black font-medium transition"
          >
            {copy.ctaPrimary}
          </a>

          <a
            href="#por-que"
            class="btn-ghost inline-flex items-center gap-2 px-6 py-3 text-xs sm:text-sm uppercase tracking-[0.12em] text-white transition"
          >
            {copy.ctaSecondary} <span class="arrow">→</span>
          </a>

          <a
            href="#contacto"
            class="btn-ghost inline-flex items-center gap-2 px-6 py-3 text-xs sm:text-sm uppercase tracking-[0.12em] text-white transition"
          >
            {copy.ctaContact} <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
  </div>
</section>

<style>
  .hero-container { }
  .video-container { overflow: hidden; }

  /* Grid texture */
  .hero-grid {
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: linear-gradient(to bottom, transparent, rgba(0,0,0,0.3) 30%, rgba(0,0,0,0.3) 80%, transparent);
  }

  /* Gold glow */
  .hero-glow {
    width: 50vw;
    height: 50vh;
    right: -5vw;
    top: 30%;
    background: radial-gradient(ellipse at center, rgba(246,173,30,0.07) 0%, transparent 70%);
  }

  .hero-lead {
  font-family: 'DM Mono', monospace;
}

  /* Animations */
  .hero-logo   { opacity: 0; animation: fadeUp 0.8s 0.2s forwards; }
  .hero-eyebrow{ opacity: 0; animation: fadeUp 0.8s 0.4s forwards;
                 font-family: 'DM Mono', 'Courier New', monospace; }
  .hero-title  { opacity: 0; animation: fadeUp 0.9s 0.6s forwards; }
  .hero-lead   { opacity: 0; animation: fadeUp 0.8s 0.85s forwards; }
  .btn-primary { opacity: 0; animation: fadeUp 0.8s 1.0s forwards; }
  .btn-ghost   { opacity: 0; animation: fadeUp 0.8s 1.05s forwards; }
  .scroll-line { opacity: 0; animation: fadeIn 1s 1.6s forwards; }

  /* Title variants */
  .title-solid,
  .title-outline,
  .title-accent {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: clamp(64px, 18vw, 164px);
    letter-spacing: -0.01em;
    display: inline;
  }
  .title-solid   { color: #ffffff; }
  .title-outline { -webkit-text-stroke: 1.5px #f6ad1e; color: transparent; }
  .title-accent  { color: #f6ad1e; }

  /* Buttons */
  .btn-primary {
    background: #f6ad1e;
    font-family: 'DM Mono', 'Courier New', monospace;
  }
  .btn-primary:hover { background: #f7b832; transform: translateX(-3px); }

  .btn-ghost {
    font-family: 'DM Mono', 'Courier New', monospace;
    border: 1px solid rgba(255,255,255,0.20);
  }
  .btn-ghost:hover { border-color: #f6ad1e; color: #f6ad1e; }
  .btn-ghost:hover .arrow { transform: translateX(4px); }
  .arrow { display: inline-block; transition: transform 0.3s ease; }

  /* Scroll line */
  .scroll-line {
    width: 1px; height: 56px;
    background: linear-gradient(to bottom, #f6ad1e, transparent);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* Responsive video — estructura original */
  @media (max-width: 767px) {
    #backgroundVideo {
      width: 200vw !important;
      height: 200vh !important;
      transform: translate(-50%, -50%) scale(2) !important;
      will-change: transform;
    }
  }
  @media (min-width: 768px) and (max-width: 1024px) {
    #backgroundVideo {
      width: 180vw !important;
      height: 180vh !important;
      transform: translate(-50%, -50%) scale(1.8) !important;
      will-change: transform;
    }
  }
  @media (min-width: 1025px) and (max-width: 1366px) {
    #backgroundVideo {
      width: 150vw !important;
      height: 150vh !important;
      transform: translate(-50%, -50%) scale(1.5) !important;
    }
  }
</style>

