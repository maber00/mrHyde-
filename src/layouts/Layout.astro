---
import { SEO } from 'astro-seo';
import Navbar from '@components/navbar/navbar.astro';

// estilos globales
import '../styles/global.css';

// fuentes — solo las que realmente se usan
import "@fontsource/bebas-neue/400.css";
import "@fontsource/dm-mono/400.css";
import "@fontsource/dm-mono/500.css";

// archivos woff2 para precargar las fuentes del LCP (título hero + texto)
import bebasNeueFont from "@fontsource/bebas-neue/files/bebas-neue-latin-400-normal.woff2";
import dmMonoFont from "@fontsource/dm-mono/files/dm-mono-latin-400-normal.woff2";

export interface Props {
  title: string;
  lang?: 'en' | 'es';
  pageDescription?: string;
}

const {
  title,
  lang = 'es',
  pageDescription,
} = Astro.props;

const siteFallback = 'https://mrHide.vercel.app';


const pageTitle = title;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || siteFallback).toString();

const twitterCreator = '@mrHide';
const twitterSite = '@mrHide';
const ogImageURL = new URL('/og-mrHide.jpg', Astro.site || siteFallback).toString();

const description =
  pageDescription ??
  (lang === 'es'
    ? 'Estudio de producción audiovisual con IA en Bogotá. Mismo estándar creativo, menos tiempo, menos costos. El único en LATAM con Zero Data Retention — tu contenido no alimenta ningún modelo externo.'
    : 'AI-powered audiovisual production studio based in Bogotá. Same creative standard, less time, lower costs. The only studio in LATAM with Zero Data Retention — your content never feeds any external model.');

const hreflangEn = new URL('/en/', Astro.site || siteFallback).toString();
// La página en español se sirve en la raíz "/", no en "/es/".
const hreflangEs = new URL('/', Astro.site || siteFallback).toString();

// ── Datos estructurados: VideoProductionCompany (se inyecta en todas las páginas) ──
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "VideoProductionCompany",
  "name": "Sr. Hide",
  "alternateName": "Sr Hide Studio",
  "url": "https://srhide.com",
  "logo": {
    "@type": "ImageObject",
    "url": "https://srhide.com/mrHyde.svg",
    "width": 200,
    "height": 50
  },
  "image": "https://srhide.com/og-mrHide.jpg",
  "description": lang === 'es'
    ? "Estudio de producción audiovisual con IA en Bogotá. Comerciales, contenido para redes sociales y postproducción con Zero Data Retention en Google Vertex AI. El único estudio en LATAM que garantiza que tu contenido no alimenta ningún modelo externo."
    : "AI-powered audiovisual production studio in Bogotá. Commercials, social media content and post-production with Zero Data Retention on Google Vertex AI. The only studio in LATAM guaranteeing your content never trains any external model.",
  "foundingDate": "2023",
  "numberOfEmployees": { "@type": "QuantitativeValue", "value": 2 },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Bogotá",
    "addressLocality": "Bogotá",
    "addressRegion": "Cundinamarca",
    "postalCode": "110111",
    "addressCountry": "CO"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": "4.7110", "longitude": "-74.0721" },
  "telephone": "+573017872595",
  "email": "hola@srhide.com",
  "areaServed": [
    { "@type": "Country", "name": "Colombia" },
    { "@type": "Country", "name": "México" },
    { "@type": "Country", "name": "Argentina" },
    { "@type": "Country", "name": "Chile" },
    { "@type": "Country", "name": "Perú" },
    { "@type": "Country", "name": "Ecuador" },
    { "@type": "Country", "name": "Venezuela" },
    { "@type": "Country", "name": "Uruguay" }
  ],
  "priceRange": "$$",
  "currenciesAccepted": "COP, USD",
  "paymentAccepted": "Transferencia bancaria, PayPal, Tarjeta de crédito",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": lang === 'es' ? "Servicios de Producción Audiovisual con IA" : "AI Audiovisual Production Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service",
        "name": lang === 'es' ? "Comerciales con IA" : "AI Commercials",
        "description": lang === 'es'
          ? "Comerciales de 15 a 60 segundos producidos con inteligencia artificial bajo dirección creativa humana. Entrega en 5-7 días hábiles."
          : "15 to 60-second commercials produced with artificial intelligence under human creative direction. Delivery in 5-7 business days." } },
      { "@type": "Offer", "itemOffered": { "@type": "Service",
        "name": lang === 'es' ? "Contenido mensual para redes sociales" : "Monthly social media content",
        "description": lang === 'es'
          ? "Paquete mensual de piezas para redes sociales con identidad visual consistente generada con IA."
          : "Monthly package of social media pieces with consistent AI-generated visual identity." } },
      { "@type": "Offer", "itemOffered": { "@type": "Service",
        "name": lang === 'es' ? "Post-producción con IA" : "AI Post-production",
        "description": lang === 'es'
          ? "Elevamos material existente: colorización, relighting, efectos y continuidad con IA."
          : "We elevate existing material: colorization, relighting, effects and continuity with AI." } },
      { "@type": "Offer", "itemOffered": { "@type": "Service",
        "name": lang === 'es' ? "Video corporativo e institucional" : "Corporate & institutional video",
        "description": lang === 'es'
          ? "Videos corporativos con dirección creativa humana y producción con IA."
          : "Corporate videos with human creative direction and AI production." } }
    ]
  },
  "founder": [
    { "@type": "Person", "name": "Manuel Bedoya",
      "jobTitle": lang === 'es' ? "Co-fundador · Dirección Creativa · CTO" : "Co-founder · Creative Direction · CTO",
      "url": "https://srhide.com/#perfiles",
      "knowsAbout": ["Producción audiovisual", "Inteligencia Artificial", "Filmmaking", "Post-producción", "Google Vertex AI"] },
    { "@type": "Person", "name": "Ana Prieto",
      "jobTitle": lang === 'es' ? "Co-fundadora · Estrategia · Negocio" : "Co-founder · Strategy · Business",
      "url": "https://srhide.com/#perfiles",
      "knowsAbout": ["Venture Capital", "Estrategia de negocio", "LATAM", "Startups", "Growth"] }
  ],
  "sameAs": [
    "https://www.instagram.com/srhide.co",
    "https://www.linkedin.com/company/srhide",
    "https://www.youtube.com/@Srhideco"
  ],
  "knowsAbout": [
    "Producción audiovisual con inteligencia artificial",
    "Zero Data Retention",
    "Google Vertex AI",
    "Comerciales con IA",
    "Filmmaking con IA",
    "Post-producción con inteligencia artificial",
    "Contenido para redes sociales con IA",
    "Avatars con IA"
  ],
  "slogan": lang === 'es' ? "Menos fricción. Más obra terminada." : "Less friction. More finished work."
};
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Precarga de las fuentes del LCP (título hero + texto) -->
    <link rel="preload" href={bebasNeueFont} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={dmMonoFont} as="font" type="font/woff2" crossorigin="anonymous" />

    <!-- Preconnect para recursos de terceros -->
    <link rel="preconnect" href="https://player.vimeo.com" />
    <link rel="preconnect" href="https://vimeo.com" />
    <link rel="dns-prefetch" href="https://f.vimeocdn.com" />

    <link rel="icon" type="image/svg+xml" href="/logoMrHyde2.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Indexación para buscadores y AI search -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- Open Graph adicionales -->
    <meta property="og:locale" content={lang === 'es' ? 'es_CO' : 'en_US'} />
    <meta property="og:site_name" content="Sr. Hide" />

    <!-- Twitter/X adicionales -->
    <meta name="twitter:label1" content={lang === 'es' ? 'Ubicación' : 'Location'} />
    <meta name="twitter:data1" content="Bogotá, Colombia" />
    <meta name="twitter:label2" content={lang === 'es' ? 'Servicio' : 'Service'} />
    <meta name="twitter:data2" content={lang === 'es' ? 'Producción Audiovisual con IA' : 'AI Audiovisual Production'} />

    <!-- Geo tags para búsquedas locales -->
    <meta name="geo.region" content="CO-DC" />
    <meta name="geo.placename" content="Bogotá" />
    <meta name="geo.position" content="4.7110;-74.0721" />
    <meta name="ICBM" content="4.7110, -74.0721" />

    <link rel="alternate" hreflang="en" href={hreflangEn} />
    <link rel="alternate" hreflang="es" href={hreflangEs} />
    <link rel="alternate" hreflang="x-default" href={hreflangEs} />


    <SEO
      title={pageTitle}
      description={description}
      canonical={canonicalURL}
      twitter={{
        creator: twitterCreator,
        site: twitterSite,
        card: "summary_large_image"
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: pageTitle,
          image: ogImageURL
        },
        image: {
          alt: "Manuel Bedoya",
          width: 1200,
          height: 630
        },
      }}
    />

    <!-- Schema.org: VideoProductionCompany -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </head>

  <body>
    <Navbar lang={lang} />
    <slot />

    <script>
      // Lazy-load de iframes con data-src (p. ej. el video de fondo decorativo).
      // Se arranca tras el evento `load` para que el iframe de terceros no
      // compita por ancho de banda con los recursos del LCP.
      const initLazyIframes = () => {
        const lazyIframes = document.querySelectorAll('iframe[data-src]');
        const load = (iframe: HTMLIFrameElement) => {
          const src = iframe.getAttribute('data-src');
          if (src && iframe.src !== src) iframe.src = src;
        };
        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                load(entry.target as HTMLIFrameElement);
                observer.unobserve(entry.target);
              }
            });
          }, { rootMargin: '200px' });
          lazyIframes.forEach(iframe => observer.observe(iframe));
        } else {
          lazyIframes.forEach(iframe => load(iframe as HTMLIFrameElement));
        }
      };

      if (document.readyState === 'complete') {
        initLazyIframes();
      } else {
        window.addEventListener('load', initLazyIframes, { once: true });
      }
    </script>
  </body>
</html>