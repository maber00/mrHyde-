---
interface Props {
  lang?: 'en' | 'es';
  title?: string;
}

const { lang = 'en', title = 'MAnuel Bedoya - FilmMaker AI' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-black text-white">
    <slot />
  </body>
</html>