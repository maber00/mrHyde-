---
import { SEO } from 'astro-seo';
import Navbar from '@components/navbar/navbar.astro';

// estilos globales
import '../styles/global.css';

// fuentes — solo las que realmente se usan
import "@fontsource/bebas-neue/400.css";
import "@fontsource/dm-mono/400.css";
import "@fontsource/dm-mono/500.css";

export interface Props {
  title: string;
  lang?: 'en' | 'es';
  pageDescription?: string;
}

const {
  title,
  lang = 'es',
  pageDescription,
} = Astro.props;

const brandName = 'Sr. Hide';
const siteFallback = 'https://mrHide.vercel.app';


const pageTitle = title;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || siteFallback).toString();

const twitterCreator = '@mrHide';
const twitterSite = '@mrHide';
const ogImageURL = new URL('/og-mrHide.jpg', Astro.site || siteFallback).toString();

const description =
  pageDescription ??
  (lang === 'es'
    ? 'Estudio de producción audiovisual con IA en Bogotá. Mismo estándar creativo, menos tiempo, menos costos. El único en LATAM con Zero Data Retention — tu contenido no alimenta ningún modelo externo.'
    : 'AI-powered audiovisual production studio based in Bogotá. Same creative standard, less time, lower costs. The only studio in LATAM with Zero Data Retention — your content never feeds any external model.');

const hreflangEn = new URL('/en/', Astro.site || siteFallback).toString();
const hreflangEs = new URL('/es/', Astro.site || siteFallback).toString();
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- Preconnect para recursos de terceros -->
    <link rel="preconnect" href="https://player.vimeo.com" />
    <link rel="preconnect" href="https://vimeo.com" />
    <link rel="dns-prefetch" href="https://f.vimeocdn.com" />

    <link rel="icon" type="image/svg+xml" href="/logoMrHyde2.svg" />
    <meta name="generator" content={Astro.generator} />

    <link rel="alternate" hreflang="en" href={hreflangEn} />
    <link rel="alternate" hreflang="es" href={hreflangEs} />
    <link rel="alternate" hreflang="x-default" href={hreflangEs} />


    <SEO
      title={pageTitle}
      description={description}
      canonical={canonicalURL}
      twitter={{
        creator: twitterCreator,
        site: twitterSite,
        card: "summary_large_image"
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: pageTitle,
          image: ogImageURL
        },
        image: {
          alt: "Manuel Bedoya",
          width: 1200,
          height: 630
        },
      }}
    />
  </head>

  <body>
    <Navbar lang={lang} />
    <slot />
  </body>
</html>