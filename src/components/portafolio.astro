import { Image } from 'astro:assets';

// Video Thumbnails
import aceiteGourmet from '../assets/portafolio/1-Aceite-Gourmet-500x500.webp';
import boniceRotoscopia from '../assets/portafolio/Bonice-Rotoscopia-500x50.webp';
import fondoLukafe from '../assets/portafolio/Fondo-Lukafe-500x500.webp';
import fondoBioexpert from '../assets/portafolio/Fondo-Bioexpert-500x500.webp';
import reelVideo from '../assets/portafolio/4-Reel-Video-Corporativo-500x500.webp';
import fondoReelMotion from '../assets/portafolio/Fondo-Reel-Motion-Graphicsok-500x500.jpg';
import tomasAereas from '../assets/portafolio/tomas-aereas-cartagena-500x500.webp';
import fondoDetrasCamaras from '../assets/portafolio/Fondo-detras-de-camaras-500x500.webp';
import tomas from '../assets/portafolio/Fondo-reel-tomas-500x500.jpg';

// IA thumbnails
import habi from '../assets/portafolio/Fondo-reel-habi-500x500.webp';
import habishort from '../assets/portafolio/Fondo-reel-habishort-500x500.webp';

import modiThumb from '../assets/ninos.jpg';
import iaThumb2 from '../assets/vive.jpg';
import iaThumb3 from '../assets/moneda.jpg';

const copy =
  lang === 'es'
    ? {
        sectionLabel: "Trabajo",
        sectionTitle: "PORTA",
        sectionTitleOutline: "FOLIO",
        intro: "Producción audiovisual, postproducción, dirección visual y exploración creativa con IA. Piezas comerciales, trabajos de realización y exploraciones donde la inteligencia artificial amplía posibilidades narrativas, técnicas y estéticas.",
        filters: [
          { id: 'all', label: 'Todo' },
          { id: 'commercials', label: 'Comerciales' },
          { id: 'video', label: 'Video' },
          { id: 'ai-explorations', label: 'Dirección IA' },
        ],
        viewProject: 'Ver proyecto →',
        closeModal: 'Cerrar',
        invalidVideo: 'Link no válido.',
      }
    : {
        sectionLabel: "Work",
        sectionTitle: "PORTA",
        sectionTitleOutline: "FOLIO",
        intro: "Audiovisual production, post-production, visual direction and creative exploration with AI. Commercial pieces, directing work and explorations where artificial intelligence expands narrative, technical and aesthetic possibilities.",
        filters: [
          { id: 'all', label: 'All' },
          { id: 'commercials', label: 'Commercials' },
          { id: 'video', label: 'Video' },
          { id: 'ai-explorations', label: 'AI Direction' },
        ],
        viewProject: 'View project →',
        closeModal: 'Close',
        invalidVideo: 'Invalid link.',
      };

const projects = [
  {
  id: 1,
  thumbnail: boniceRotoscopia,
  title: "ROTOSCOPIA – BONICE",
  category: "commercials",
  categoryLabel: lang === 'es' ? "Comerciales" : "Commercials",
  videoUrl: "https://www.youtube.com/watch?v=70fK2Odcw0A",
  description: lang === 'es'
    ? "Pieza comercial con técnica de rotoscopía para Bonice. Realizada en colaboración con Render Medios Audiovisuales, donde participé en toda postproducción visual."
: "Commercial piece using rotoscopy technique for Bonice. Made in collaboration with Render Medios Audiovisuales, where I handled the full visual post-production."},

  {
  id: 2,
  thumbnail: fondoBioexpert,
  title: "Comercial Bioexpert Promo - Motion Graphics",
  category: "commercials",
  categoryLabel: lang === 'es' ? "Comerciales" : "Commercials",
  videoUrl: "https://www.youtube.com/watch?v=ICE1dRRTCoc",
  description: lang === 'es'
    ? "Pieza promocional con motion graphics para Bioexpert. Concepto visual basado en dinamismo y claridad de marca. Realizada en Render Medios Audiovisuales, donde participé como postproductor a cargo de la animación y gráficas en movimiento."
    : "Promotional piece with motion graphics for Bioexpert. Visual concept built around brand clarity and dynamism. Made at Render Medios Audiovisuales, where I worked as post-producer handling animation and motion graphics."
},
  
  {
  id: 3,
  thumbnail: fondoReelMotion,
  title: "Reel Motion Graphics",
  category: "video",
  categoryLabel: "Video",
  videoUrl: "https://www.youtube.com/watch?v=-EAsCig1XzM",
  description: lang === 'es'
    ? "Reel de animación y motion graphics desarrollado en After Effects y Cinema 4D, con IA como parte del proceso creativo. Piezas que combinan técnica y concepto visual para comunicar con movimiento."
    : "Animation and motion graphics reel developed in After Effects and Cinema 4D, with AI as part of the creative process. Pieces that combine technique and visual concept to communicate through movement."
},
  {
  id: 4,
  thumbnail: tomas,
  title: "Reel secuencia de tomas",
  category: "video",
  categoryLabel: "Video",
  videoUrl: "https://www.youtube.com/watch?v=YXQRJrOE-sU",
  description: lang === 'es'
    ? "Lo que hemos construido, pieza a pieza. Realización e inteligencia artificial unidas para llevar cada proyecto más lejos. Esto es lo que hacemos, y apenas es el comienzo."
    : "What we have built, piece by piece. Filmmaking and artificial intelligence working together to push every project further. This is what we do, and this is just the beginning."
},
  {
    id: 5,
    thumbnail: modiThumb,
    title: "Miniserie Animada – Modi",
    category: "video",
    categoryLabel: lang === 'es' ? "Dirección Creativa con IA" : "AI Creative Direction",
    videoUrl: "https://youtu.be/c_lgP7DQoT4",
    description: lang === 'es'
    ? "Miniserie animada para la marca Modi. Ilustración y animación realizadas en After Effects con apoyo de IA. Una historia de niños que aprenden a enfrentar sus adversidades juntos, desde la amistad y el valor de la compañía."
    : "Animated miniseries for the brand Modi. Illustrated and animated in After Effects with AI support. A story about children learning to face their challenges together, through friendship and the strength of companionship."
  },
  
  {
    id: 7,
    thumbnail: iaThumb3,
    title: "Exploración IA 03",
    category: "ai-explorations",
    categoryLabel: lang === 'es' ? "Dirección Creativa con IA" : "AI Creative Direction",
    videoUrl: "https://youtu.be/qYoVAp5vsz8"
  },
  {
  id: 8,
  thumbnail: habi,
  title: "Habi",
  category: "commercials",
  categoryLabel: lang === 'es' ? "Comercial IA" : "AI Commercial",
  videoUrl: "https://youtu.be/dG3cfShPs20",
  description: lang === 'es'
    ? "Detrás de cada imagen, una visión humana. La IA como herramienta de realización: precisa, potente y al servicio del concepto. Guión, dirección creativa y guión técnico desarrollados por nosotros. El resto, en manos de la tecnología."
    : "Behind every image, a human vision. AI as the production tool: precise, powerful and at the service of the concept. Script, creative direction and technical breakdown developed by us. The rest, in the hands of technology."
},
  {
  id: 9,
  thumbnail: habishort,
title: lang === 'es' ? "Habi – Reel Vertical 9:16" : "Habi – Vertical Reel 9:16",
  category: "commercials",
categoryLabel: lang === 'es' ? "Comercial IA · Instagram / TikTok" : "AI Commercial · Instagram / TikTok",
  videoUrl: "https://www.youtube.com/shorts/4KAltSwgi74",
  description: lang === 'es'
    ? "Cada segundo tiene intención. Reel de piezas realizadas para formatos verticales — YouTube, Instagram y TikTok — donde la dirección creativa y la inteligencia artificial se unen para contar más en menos tiempo."
    : "Every second is intentional. A reel of pieces made for vertical formats — YouTube, Instagram and TikTok — where creative direction and artificial intelligence come together to tell more in less time."
},
];
---

<section id={id ?? "portafolio"} class="bg-black text-white py-24">
  <div class="px-6 md:px-10 lg:px-20">

    <!-- Header -->
    <div class="mb-12">
      <p class="sec-label">{copy.sectionLabel}</p>
      <h2 class="sec-title">
        {copy.sectionTitle}<span class="sec-title-outline">{copy.sectionTitleOutline}</span>
      </h2>
      <p class="sec-intro">{copy.intro}</p>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-2 mb-10">
      {copy.filters.map((filter, index) => (
        <button
          type="button"
          class:list={["tag-filter", index === 0 ? "active" : ""]}
          data-filter={filter.id}
        >
          {filter.label}
        </button>
      ))}
    </div>

    <!-- Grid -->
    <div class="project-grid">
      {projects.map(project => (
        <div
          class="project-item group"
          data-category={project.category}
          data-title={project.title}
          data-video-url={project.videoUrl}
          data-category-label={project.categoryLabel}
            data-description={project.description ?? ''}

        >
          <Image
            src={project.thumbnail}
            alt={project.title}
            class="project-img"
            width={500}
            height={500}
          />
          <!-- Hover overlay -->
          <div class="project-overlay">
            <p class="project-category">{project.categoryLabel}</p>
            <p class="project-title-hover">{project.title}</p>
            <span class="project-cta">{copy.viewProject}</span>
          </div>
        </div>
      ))}
    </div>

  </div>

  <!-- Modal -->
  <div id="portfolioModal" class="modal fixed inset-0 z-50 hidden">
    <div id="modalOverlay" class="absolute inset-0 bg-black/92"></div>

    <div class="relative flex flex-col lg:flex-row min-h-full items-center justify-center p-4 md:p-10 lg:p-20 gap-6 lg:gap-10 overflow-y-auto">

      <!-- Video -->
      <div id="videoWrapper" class="w-full lg:w-2/3 aspect-video bg-black/50 relative border border-white/10">
  <div id="carouselContainer" class="w-full h-full"></div>
</div>

      <!-- Info -->
      <div class="w-full lg:w-1/3">
        <p class="modal-category" id="modalTags"></p>
        <h2 class="modal-title" id="modalTitle"></h2>
          <p class="modal-description" id="modalDescription"></p>

      </div>

      <!-- Close -->
      <button
        id="closeModalBtn"
        type="button"
        aria-label={copy.closeModal}
        class="modal-close"
      >
        ✕
      </button>
    </div>
  </div>
</section>

<style>
  /* ── Section label ── */
  .sec-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #f6ad1e;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .sec-label::before {
    content: '';
    width: 24px;
    height: 1px;
    background: #f6ad1e;
    display: block;
  }

  /* ── Section title ── */
  .sec-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(72px, 12vw, 160px);
    line-height: 0.88;
    letter-spacing: -0.01em;
    color: #ffffff;
    margin-bottom: 24px;
  }
  .sec-title-outline {
    font-family: 'Bebas Neue', sans-serif;
    -webkit-text-stroke: 1.5px #f6ad1e;
    color: transparent;
  }

  /* ── Intro ── */
  .sec-intro {
    font-family: 'DM Mono', monospace;
    font-size: 17px;
    color: rgba(255,255,255,0.45);
    line-height: 1.85;
    max-width: 560px;
  }

  /* ── Filters ── */
  .tag-filter {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 8px 18px;
    background: transparent;
    cursor: pointer;
    transition: all 0.25s ease;
  }
  .tag-filter:hover,
  .tag-filter.active {
    background: #f6ad1e;
    border-color: #f6ad1e;
    color: #000000;
  }
.modal-description {
  font-family: 'DM Mono', monospace;
  font-size: 13px;
  color: rgba(255,255,255,0.45);
  line-height: 1.8;
  margin-top: 16px;
}
  /* ── Project grid ── */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
  }
  @media (min-width: 768px) {
    .project-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1024px) {
    .project-grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* ── Project item ── */
  .project-item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    cursor: pointer;
    background: #111;
  }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease, filter 0.4s ease;
  }
  .project-item:hover .project-img {
    transform: scale(1.06);
    filter: brightness(0.35);
  }

  /* ── Hover overlay ── */
  .project-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 20px;
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .project-item:hover .project-overlay { opacity: 1; }

  .project-category {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #f6ad1e;
    margin-bottom: 6px;
  }
  .project-title-hover {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(18px, 2vw, 26px);
    line-height: 1;
    color: #ffffff;
    letter-spacing: 0.02em;
    margin-bottom: 10px;
  }
  .project-cta {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
  }

  /* ── Modal ── */
  .modal { transition: opacity 0.3s ease; }
  .modal.hidden { opacity: 0; pointer-events: none; }
  .modal:not(.hidden) { 
  opacity: 1; 
  background: rgba(0, 0, 0, 0.92);
}

  .modal-category {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #f6ad1e;
    margin-bottom: 12px;
  }
  .modal-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(28px, 3vw, 44px);
    line-height: 1;
    color: #ffffff;
    letter-spacing: 0.02em;
  }

  .modal-close {
    position: absolute;
    top: 24px; right: 24px;
    font-family: 'DM Mono', monospace;
    font-size: 16px;
    color: rgba(255,255,255,0.5);
    background: none;
    border: 1px solid rgba(255,255,255,0.15);
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: all 0.3s;
  }
  .modal-close:hover {
    border-color: #f6ad1e;
    color: #f6ad1e;
  }

  .video-wrapper,
  .video-wrapper iframe {
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('portfolioModal');
    const modalOverlay = document.getElementById('modalOverlay');
    const closeBtn = document.getElementById('closeModalBtn');
    const filterButtons = document.querySelectorAll('.tag-filter');
    const projectItems = document.querySelectorAll('.project-item');
    const modalTitle = document.getElementById('modalTitle');
    const modalTags = document.getElementById('modalTags');
    const modalDescription = document.getElementById('modalDescription');
    const carouselContainer = document.getElementById('carouselContainer');

    function getYouTubeVideoId(url: string) {
  const shortsRegex = /youtube\.com\/shorts\/([^#&?]*)/;
  const shortsMatch = url.match(shortsRegex);
  if (shortsMatch && shortsMatch[1].length === 11) return shortsMatch[1];

  const regex = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
  const match = url.match(regex);
  return (match && match[2].length === 11) ? match[2] : null;
}


    function getVimeoVideoId(url: string) {
      const regex = /vimeo\.com\/(?:manage\/videos\/)?(\d+)/;
      const match = url.match(regex);
      return match ? match[1] : null;
    }

    function isYouTubeShort(url: string) {
  return url.includes('/shorts/');
}

    // Filters
    filterButtons.forEach((button, index) => {
      button.addEventListener('click', () => {
        const filterValue = button.getAttribute('data-filter') || 'all';
        filterButtons.forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');
        projectItems.forEach(item => {
          const category = item.getAttribute('data-category') || '';
          const shouldShow = filterValue === 'all' || category === filterValue;
          item.classList.toggle('hidden', !shouldShow);
        });
      });
      if (index === 0) button.classList.add('active');
    });

    // Open modal
    if (modal && closeBtn && carouselContainer && modalTitle && modalTags) {
      projectItems.forEach(item => {
        item.addEventListener('click', () => {
          const title = item.getAttribute('data-title') || '';
          const videoUrl = item.getAttribute('data-video-url') || '';
          const categoryLabel = item.getAttribute('data-category-label') || '';
          const description = item.getAttribute('data-description') || '';

          const youtubeId = getYouTubeVideoId(videoUrl);
const vimeoId = getVimeoVideoId(videoUrl);
const isShort = isYouTubeShort(videoUrl);

modal.classList.remove('hidden');
document.body.style.overflow = 'hidden';
carouselContainer.innerHTML = '';

const videoWrapper = document.getElementById('videoWrapper');
if (videoWrapper) {
  if (isShort) {
    videoWrapper.className = 'relative bg-black/50 border border-white/10 mx-auto';
    videoWrapper.style.width = 'auto';
    videoWrapper.style.height = '70vh';
    videoWrapper.style.aspectRatio = '9 / 16';
  } else {
    videoWrapper.className = 'w-full lg:w-2/3 bg-black/50 relative border border-white/10';
    videoWrapper.style.width = '';
    videoWrapper.style.height = '';
    videoWrapper.style.aspectRatio = '';
  }
}

if (youtubeId) {
  carouselContainer.innerHTML = `
    <div class="video-wrapper w-full h-full">
      <iframe class="w-full h-full"
        src="https://www.youtube.com/embed/${youtubeId}?autoplay=1&rel=0"
                  frameborder="0"
                  allow="autoplay; encrypted-media; fullscreen; picture-in-picture"
                  allowfullscreen></iframe>
              </div>`;
          } else if (vimeoId) {
            carouselContainer.innerHTML = `
              <div class="video-wrapper w-full h-full">
                <iframe class="w-full h-full"
                  src="https://player.vimeo.com/video/${vimeoId}?autoplay=1"
                  frameborder="0"
                  allow="autoplay; fullscreen; picture-in-picture"
                  allowfullscreen></iframe>
              </div>`;
          } else {
            carouselContainer.innerHTML = `
              <div class="w-full h-full flex items-center justify-center text-white/40 text-sm font-mono">
                Link no válido
              </div>`;
          }

          modalTitle.textContent = title;
          modalTags.textContent = categoryLabel;
          if (modalDescription) modalDescription.textContent = description;
        });
      });

      const closeModal = () => {
        modal.classList.add('hidden');
        document.body.style.overflow = '';
        carouselContainer.innerHTML = '';
        if (modalDescription) modalDescription.textContent = '';
      };

      closeBtn.addEventListener('click', closeModal);
      modalOverlay?.addEventListener('click', closeModal);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeModal();
      });
    }
  });
</script>