---
const currentPath = Astro.url.pathname;

const isSpanish = currentPath.startsWith('/es');
const targetPath = isSpanish
  ? currentPath.replace(/^\/es/, '/en')
  : currentPath.replace(/^\/en/, '/es');

const safeTarget = targetPath === currentPath
  ? (isSpanish ? '/en/' : '/es/')
  : targetPath;
---

<a
  href={safeTarget}
  class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3 py-2 text-sm text-white backdrop-blur transition hover:bg-white/20"
  aria-label={isSpanish ? 'Switch to English' : 'Cambiar a español'}
>
  {
    isSpanish ? (
      <>
        <img src="https://flagcdn.com/w20/gb.png" alt="English" class="h-4 w-5 rounded-sm object-cover" />
        <span>EN</span>
      </>
    ) : (
      <>
        <img src="https://flagcdn.com/w20/es.png" alt="Español" class="h-4 w-5 rounded-sm object-cover" />
        <span>ES</span>
      </>
    )
  }
</a>