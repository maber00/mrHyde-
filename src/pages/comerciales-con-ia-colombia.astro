---
import ServicePage from "../layouts/ServicePage.astro";

const features = [
  {
    num: "01",
    title: "EL BRIEF PRIMERO",
    body: "Cada pieza empieza con un objetivo de negocio, un concepto y un guión. No encendemos nada sin saber exactamente qué tiene que lograr el comercial.",
  },
  {
    num: "02",
    title: "ENTREGA EN DÍAS",
    body: "Lo que antes tardaba cuatro semanas hoy tarda cinco días. Eso cambia la forma en que las marcas reaccionan a temporadas, lanzamientos y oportunidades de mercado.",
  },
  {
    num: "03",
    title: "ZERO DATA RETENTION",
    body: "Tu campaña no anunciada, tu brief, tu identidad de marca — no se almacenan ni alimentan ningún modelo externo. Garantía contractual de Google sobre Vertex AI.",
  },
  {
    num: "04",
    title: "BOGOTÁ Y TODA LATAM",
    body: "Operamos de forma remota en Colombia, México, Argentina, Chile, Perú, Ecuador y Uruguay. Mismo estándar creativo, sin importar dónde estés.",
  },
];

const faqs = [
  {
    q: "¿Cuánto cuesta un comercial en Colombia?",
    a: "Depende de la duración, la complejidad y el número de versiones. En general es significativamente más económico que una producción tradicional equivalente. Contáctanos y te respondemos con una propuesta en 48 horas.",
  },
  {
    q: "¿Qué incluye el proceso?",
    a: "Brief estratégico, concepto creativo, guión, dirección visual, producción, edición, corrección de color, diseño sonoro y entrega en los formatos que necesites — horizontal, vertical 9:16, cuadrado 1:1.",
  },
  {
    q: "¿La calidad es comparable a una producción tradicional?",
    a: "Sí. La diferencia no está en el resultado sino en el tiempo y el costo del proceso. El criterio creativo, la dirección y el acabado son los mismos.",
  },
  {
    q: "¿Para qué tipo de marcas trabajan?",
    a: "Trabajamos con marcas de consumo, startups, tecnología, retail, servicios financieros y agencias en Colombia y LATAM. Especialmente útiles para quien necesita comunicar rápido o maneja contenido confidencial.",
  },
];
---

<ServicePage
  lang="es"
  title="Comerciales en Colombia | Sr. Hide — Producción Audiovisual"
  description="Producimos comerciales de 15 a 60 segundos en Colombia. De brief a entrega en días, no semanas. Zero Data Retention sobre Google Vertex AI."
  label="Servicios"
  h1="COMERCIALES"
  h1Outline="COLOMBIA Y LATAM"
  breadcrumbName="Comerciales"
  lead="Producimos comerciales de 15 a 60 segundos. Empezamos con el objetivo, desarrollamos el concepto y lo llevamos a pantalla — en días, no semanas. Con el mismo criterio creativo de una producción de alto presupuesto, y Zero Data Retention para lo que no puede salir de tu marca."
  features={features}
  faqs={faqs}
  ctaText="¿Tienes un brief listo? Cuéntanos el proyecto y te respondemos en menos de 24 horas."
  ctaLabel="Hablar con el equipo →"
