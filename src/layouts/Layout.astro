---
import { SEO } from 'astro-seo';
import Navbar from '@components/navbar/navbar.astro';

// estilos globales
import '../styles/global.css';

// fuentes
import '@fontsource/poppins/300.css';
import '@fontsource/poppins/400.css';
import '@fontsource/poppins/500.css';
import '@fontsource/poppins/600.css';
import '@fontsource/poppins/700.css';
import "@fontsource/noto-serif/300.css";
import '@fontsource/noto-serif/400.css';
import '@fontsource/noto-serif/700.css';
import '@fontsource/roboto/400.css';
import '@fontsource/roboto/300.css';
import "@fontsource/noto-serif";
import "@fontsource/permanent-marker";
import "@fontsource/bebas-neue";
import "@fontsource/bebas-neue/400.css";
import "@fontsource/libre-baskerville/400.css";
import "@fontsource/libre-baskerville/700.css";

export interface Props {
  title: string;
  lang?: 'en' | 'es';
  pageDescription?: string;
}

const {
  title,
  lang = 'en',
  pageDescription,
} = Astro.props;

const brandName = 'Manuel Bedoya';
const siteFallback = 'https://manuelbedoya.vercel.app';

const pageTitle = title;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || siteFallback).toString();

const twitterCreator = '@mrHide';
const twitterSite = '@mrHide';
const ogImageURL = new URL('/og-mrHide.jpg', Astro.site || siteFallback).toString();

const description =
  pageDescription ??
  (lang === 'es'
    ? 'Realización audiovisual con procesos y automatización: video, podcast, animación y contenido continuo. Menos fricción. Más obra terminada.'
    : 'Audiovisual direction, post-production and AI-assisted workflows for brands that need clear, cinematic and technically solid visual content.');

const hreflangEn = new URL('/', Astro.site || siteFallback).toString();
const hreflangEs = new URL('/es/', Astro.site || siteFallback).toString();
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <link rel="alternate" hreflang="en" href={hreflangEn} />
    <link rel="alternate" hreflang="es" href={hreflangEs} />
    <link rel="alternate" hreflang="x-default" href={hreflangEn} />

    <SEO
      title={pageTitle}
      description={description}
      canonical={canonicalURL}
      twitter={{
        creator: twitterCreator,
        site: twitterSite,
        card: "summary_large_image"
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: pageTitle,
          image: ogImageURL
        },
        image: {
          alt: "Manuel Bedoya",
          width: 1200,
          height: 630
        },
      }}
    />

    <link
      rel="preload"
      href="/fonts/poppins-v20-latin-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/roboto-v30-latin-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>

  <body>
    <Navbar lang={lang} />
    <slot />
  </body>
</html>